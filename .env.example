# ============================================================
# CVA Deal — Environment Variables
# Copy this file to .env (or .env.local) and fill in real values.
# ============================================================

# ── Core app ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/cvadeal"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── OSINT module (lead enrichment) ──────────────────────────
# Redis backs the BullMQ queue that the OSINT worker consumes
# (run `pnpm run worker` or `pnpm dev:all`). Defaults to localhost.
REDIS_URL="redis://localhost:6379"

# Used by the AI Reasoner to draft sales insights from an enriched
# profile. Optional — enrichment still runs without it, just without
# the AI-written summary.
OPENAI_API_KEY=""

# Optional log verbosity for the OSINT pipeline (debug|info|warn|error)
OSINT_LOG_LEVEL="info"

# --- Optional paid OSINT providers ---
# None of these are required: without any of them, the OSINT module
# still does real web scraping via the free bing_legacy/duckduckgo_legacy
# (HTML scraping) and web_fetcher providers. Add these only to get
# higher-quality/more-reliable results from the official APIs.
GOOGLE_CSE_API_KEY=""
GOOGLE_CSE_ID=""
# Real Google search results without needing a Custom Search Engine ID
# (get a key at https://serpapi.com/manage-api-key)
SERPAPI_API_KEY=""
BING_API_KEY=""
NEWSAPI_KEY=""
PROXYCURL_API_KEY=""

# Apify — enriches Instagram/Facebook profiles found by SocialAgent with
# real bio/followers/following/posts data (get a token at
# https://console.apify.com/settings/integrations)
APIFY_API_TOKEN=""

# ── Google OAuth login ───────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Payments (Mercado Pago) ──────────────────────────────────
MP_ACCESS_TOKEN=""

# ── File storage (property images/plans) ─────────────────────
AWS_BUCKET_NAME=""
AWS_REGION=""
AWS_FOLDER_PREFIX=""

# ── WhatsApp / Meta integration ───────────────────────────────
META_ACCESS_TOKEN=""
META_VERIFY_TOKEN=""
WEB_APP_ID=""

# ── Notifications ─────────────────────────────────────────────
NOTIF_ID_CONFIRMACIN_DE_RESERVA=""
NOTIF_ID_NUEVA_RESERVA_ADMIN=""

# ── Misc ────────────────────────────────────────────────────
ABACUSAI_API_KEY=""
